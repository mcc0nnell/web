---
// GLADcast output surface — a clean, distributed render node for one room.
//
// This page is for projectors, LED walls, livestream capture, OBS browser
// sources, venue screens, and scan converters: no chrome, no status text,
// no cursor, no scrollbars, no layout shift. It subscribes read-only to
// /api/ops/ws and renders the room's synchronized state; all mutations go
// through the operator console.
//
// Query parameters:
//   ?debug=1          diagnostics overlay (connection, revision, transport
//                     drift, control-signal age, media status, fps/GPU)
//   ?standby=slate    broadcast standby slate before first sync (default:
//                     clean black — never an "acquiring signal" message)
//   ?bg=<css-color>   page background behind the canvas (default black)
export const prerender = false;
const { room } = Astro.params;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex" />
    <title>GLADcast — OUTPUT {room}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Instrument+Serif&family=Outfit:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;600&display=swap"
    />
  </head>
  <body data-room={room}>
    <div id="gladcast-output"></div>
    <script>
      import { bootOutput } from '../../scripts/gladcast/receiver.js';
      const params = new URLSearchParams(location.search);
      const debug = params.get('debug') === '1';
      const bg = params.get('bg');
      if (bg && /^[a-zA-Z0-9#(),.% -]{1,40}$/.test(bg)) document.body.style.background = bg;
      try {
        bootOutput(document.getElementById('gladcast-output'), {
          room: document.body.dataset.room || 'main-hall',
          debug,
          standby: params.get('standby') === 'slate' ? 'slate' : 'black',
        });
      } catch (err) {
        // Clean feed stays clean: errors surface only in debug mode.
        if (debug) {
          document.body.innerHTML =
            '<pre style="padding:2rem;font-family:monospace;color:#DC2626;">Output could not start: ' +
            (err instanceof Error ? err.message : String(err)) +
            '</pre>';
        }
        console.error(err);
      }

      // Hide the cursor after 3 s of stillness — venue screens show no pointer.
      let cursorTimer: number | undefined;
      const armCursor = () => {
        document.body.classList.remove('cursor-hidden');
        clearTimeout(cursorTimer);
        cursorTimer = setTimeout(() => document.body.classList.add('cursor-hidden'), 3000);
      };
      window.addEventListener('mousemove', armCursor);
      armCursor();
    </script>
    <style>
      html,
      body {
        margin: 0;
        background: #000;
        height: 100%;
        overflow: hidden;
      }
      body.cursor-hidden,
      body.cursor-hidden * {
        cursor: none;
      }
      #gladcast-output {
        display: grid;
        place-items: center;
        height: 100vh;
      }
      .gc-output-canvas {
        max-width: 100vw;
        max-height: 100vh;
      }
      .gc-output-hud {
        position: fixed;
        top: 10px;
        left: 12px;
        margin: 0;
        padding: 10px 14px;
        background: rgba(10, 14, 22, 0.85);
        border: 1px solid #dc2626;
        border-radius: 6px;
        color: #e8ecf1;
        font: 11px/1.6 'IBM Plex Mono', monospace;
        letter-spacing: 0.04em;
        pointer-events: none;
        white-space: pre;
      }
    </style>
  </body>
</html>
