---
// GLADcast output surface — a clean render node mirroring one RoomDO room.
// Fullscreen this on the projector / stage screen, or capture it as an OBS
// browser source. Read-only: it subscribes to /api/ops/ws and renders the
// room's `visual` slice; all mutations go through the operator console.
export const prerender = false;
const { room } = Astro.params;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex" />
    <title>GLADcast — OUTPUT {room}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Instrument+Serif&family=Outfit:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;600&display=swap"
    />
  </head>
  <body data-room={room}>
    <div id="gladcast-output"></div>
    <script>
      import { bootOutput } from '../../scripts/gladcast/receiver.js';
      const room = document.body.dataset.room || 'main-hall';
      try {
        bootOutput(document.getElementById('gladcast-output'), room);
      } catch (err) {
        document.body.innerHTML =
          '<p style="padding:2rem;font-family:monospace;color:#DC2626;">Output could not start: ' +
          (err && err.message ? err.message : err) +
          '</p>';
        console.error(err);
      }
    </script>
    <style>
      html,
      body {
        margin: 0;
        background: #000;
        height: 100%;
        overflow: hidden;
      }
      #gladcast-output {
        display: grid;
        place-items: center;
        height: 100vh;
      }
      .gc-output-canvas {
        max-width: 100vw;
        max-height: 100vh;
      }
      .gc-output-status {
        position: fixed;
        bottom: 12px;
        right: 16px;
        font-family: 'IBM Plex Mono', monospace;
        font-size: 11px;
        letter-spacing: 0.14em;
        color: #8a93a6;
        opacity: 0.8;
      }
      .gc-output-status.live {
        color: #34d399;
      }
    </style>
  </body>
</html>
