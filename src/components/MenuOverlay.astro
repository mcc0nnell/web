---
const { links } = Astro.props;
---

<div class="overlay" id="menu" data-open="false" aria-hidden="true">
  <div class="panel">
    <div class="top">
      <div class="brand">Menu</div>
      <button class="closeBtn" type="button" id="closeMenu">Close</button>
    </div>

    <div class="cols">
      <div class="group">
        <h3 class="groupTitle">Follow</h3>
        <a href="#" onclick="return false;">Instagram <span>/ soon</span></a>
        <a href="#" onclick="return false;">YouTube <span>/ optional</span></a>
        <a href="#" onclick="return false;">Spotify <span>/ optional</span></a>
      </div>

      <div class="group">
        <h3 class="groupTitle">Links</h3>
        {links?.map((l) => (
          <a href={l.href}>{l.label}</a>
        ))}
      </div>

      <div class="group">
        <h3 class="groupTitle">Work</h3>
        <a href="#signals">Signals</a>
        <a href="#status">Status</a>
        <a href="#work">Selected Work</a>
      </div>

      <div class="group">
        <h3 class="groupTitle">Contact</h3>
        <a href={links?.find((l) => l.label.toLowerCase() === 'email')?.href ?? 'mailto:hi@mcc0nnell.org'}>Email</a>
      </div>
    </div>
  </div>
</div>

<script>
  const menu = document.getElementById('menu');
  const openBtn = document.getElementById('openMenu');
  const closeBtn = document.getElementById('closeMenu');

  const setOpen = (open) => {
    menu.dataset.open = open ? 'true' : 'false';
    menu.setAttribute('aria-hidden', open ? 'false' : 'true');
    document.body.style.overflow = open ? 'hidden' : '';
  };

  openBtn?.addEventListener('click', () => setOpen(true));
  closeBtn?.addEventListener('click', () => setOpen(false));

  menu?.addEventListener('click', (e) => {
    if (e.target === menu) setOpen(false);
  });

  window.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') setOpen(false);
  });
</script>
