---
import '../../styles/global.css';

const posts = [
  {
    slug: 'how-we-built-a-deaf-conference-broadcast-layer',
    title: 'How We Built a Deaf Conference Broadcast Layer',
    dek: 'What started as a conference website became live civic infrastructure — and nearly broke in the process. Lessons from the National Association of the Deaf’s 58th Biennial Conference in San Francisco.',
    date: 'July 6, 2026',
    kicker: 'Field Notes',
    readingTime: '12 min read',
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Journal — Robert McConnell</title>
    <meta name="description" content="Field notes on accessibility infrastructure, broadcast production, and Deaf civic technology." />
    <meta name="theme-color" content="#0F1520" />
    <meta name="color-scheme" content="dark" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Outfit:wght@300;400;500;600;700&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet" />

    <!-- Open Graph -->
    <meta property="og:title" content="Journal — Robert McConnell" />
    <meta property="og:description" content="Field notes on accessibility infrastructure, broadcast production, and Deaf civic technology." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://mcc0nnell.org/blog/" />

    <link rel="canonical" href="https://mcc0nnell.org/blog/" />
    <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><rect width='100' height='100' rx='16' fill='%231B2333'/><text x='50' y='66' font-size='52' text-anchor='middle' fill='%23DC2626' font-family='Georgia,serif'>M</text></svg>" />
  </head>

  <body>
    <!-- ============ Navigation ============ -->
    <nav class="nav scrolled" id="nav">
      <div class="nav__inner">
        <a href="/" class="nav__brand">mcc0nnell.org</a>
        <button class="nav__toggle" id="navToggle" type="button" aria-label="Toggle menu">Menu</button>
        <div class="nav__links" id="navLinks">
          <a href="/#work">Work</a>
          <a href="/#writing">Writing</a>
          <a href="/blog/">Journal</a>
          <a href="/#sf26">SF26</a>
          <a href="/#connect">Connect</a>
        </div>
      </div>
    </nav>

    <!-- ============ Blog Index ============ -->
    <section class="section" id="journal" style="padding-top: clamp(120px, 18vh, 200px);">
      <div class="container">
        <div class="section__header">
          <div>
            <span class="label">Journal</span>
            <h2 class="section__title">Field notes</h2>
          </div>
          <span class="section__count">{String(posts.length).padStart(2, '0')} entr{posts.length === 1 ? 'y' : 'ies'}</span>
        </div>

        <div class="blog-list">
          {posts.map((post) => (
            <a class="post-card" href={`/blog/${post.slug}`}>
              <div class="post-card__meta">
                <span class="label">{post.kicker}</span>
                <span>{post.date}</span>
                <span>{post.readingTime}</span>
              </div>
              <h3 class="post-card__title">{post.title}</h3>
              <p class="post-card__dek">{post.dek}</p>
              <span class="post-card__more">Read &rarr;</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- ============ Footer ============ -->
    <footer class="footer">
      <div class="container">
        <div class="footer__inner">
          <span class="footer__brand">mcc0nnell.org</span>
          <span class="footer__note">Built with quiet authority.</span>
        </div>
      </div>
    </footer>

    <script>
      const toggle = document.getElementById('navToggle');
      const links = document.getElementById('navLinks');
      toggle?.addEventListener('click', () => links?.classList.toggle('open'));
      links?.querySelectorAll('a').forEach((a) =>
        a.addEventListener('click', () => links?.classList.remove('open'))
      );
    </script>
  </body>
</html>
