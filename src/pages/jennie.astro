<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Jennie DeLeon — ASL × Music × Theater</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@500;600;700;800&family=Space+Grotesk:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
  :root{
    --bone:#FAFAF6;
    --ink:#101010;
    --ink-soft:#3B3B38;
    --grey:#8B8B84;
    --line:#E4E4DC;
    --poppy:#C91140;        /* lipstick rouge */
    --poppy-hot:#E8194B;
    --fog:#EFEFE9;
  }

  *{box-sizing:border-box;margin:0;padding:0}
  html{scroll-behavior:smooth}
  body{
    background:var(--bone);
    color:var(--ink);
    font-family:"Space Grotesk",system-ui,sans-serif;
    font-weight:400;
    line-height:1.55;
    -webkit-font-smoothing:antialiased;
    overflow-x:hidden;
  }
  ::selection{background:var(--poppy);color:#fff}
  a{color:inherit}
  img{display:block;max-width:100%}

  .wrap{max-width:1240px;margin:0 auto;padding:0 clamp(20px,4vw,48px)}

  .syne{font-family:"Syne",sans-serif}
  .eyebrow{
    font-size:.72rem;letter-spacing:.26em;text-transform:uppercase;
    color:var(--poppy);font-weight:500;
  }

  /* ============ NAV ============ */
  .nav{
    position:fixed;top:0;left:0;right:0;z-index:50;
    display:flex;justify-content:space-between;align-items:center;
    padding:18px clamp(20px,4vw,48px);
    background:color-mix(in srgb, var(--bone) 86%, transparent);
    backdrop-filter:blur(12px);
    border-bottom:1px solid var(--line);
  }
  .nav .logo{font-family:"Syne",sans-serif;font-weight:800;font-size:1rem;letter-spacing:-.01em;text-decoration:none}
  .nav .logo span{color:var(--poppy)}
  .nav-links{display:flex;gap:28px;align-items:center}
  .nav-links a{
    text-decoration:none;font-size:.8rem;letter-spacing:.12em;text-transform:uppercase;
    color:var(--ink-soft);transition:color .2s;
  }
  .nav-links a:hover{color:var(--poppy)}
  .nav-links .book{
    background:var(--ink);color:var(--bone);padding:10px 20px;border-radius:100px;
    transition:background .2s, transform .2s;
  }
  .nav-links .book:hover{background:var(--poppy);color:#fff;transform:translateY(-1px)}

  /* ============ HERO ============ */
  .hero{
    min-height:100svh;
    display:flex;flex-direction:column;justify-content:flex-end;
    padding-top:110px;position:relative;
  }
  .hero-top{
    display:grid;grid-template-columns:1.25fr .75fr;gap:clamp(24px,4vw,64px);
    align-items:end;padding-bottom:clamp(28px,4vh,56px);
  }
  .hero h1{
    font-family:"Syne",sans-serif;font-weight:800;
    font-size:clamp(3.4rem,11.5vw,9.5rem);
    line-height:.88;letter-spacing:-.035em;
    text-transform:uppercase;
  }
  .hero h1 .accent{color:var(--poppy)}
  .hero h1 .outline{
    color:transparent;
    -webkit-text-stroke:2px var(--ink);
  }
  .hero-side{padding-bottom:12px}
  .hero-side p{
    font-size:clamp(1rem,1.4vw,1.15rem);color:var(--ink-soft);max-width:32ch;line-height:1.6;
  }
  .hero-side p b{color:var(--ink);font-weight:600}
  .hero-tags{display:flex;flex-wrap:wrap;gap:8px;margin-top:20px}
  .tag{
    font-size:.72rem;letter-spacing:.14em;text-transform:uppercase;
    border:1px solid var(--ink);border-radius:100px;padding:7px 14px;font-weight:500;
  }
  .tag.hot{background:var(--poppy);border-color:var(--poppy);color:#fff}

  .hero-split{
    display:grid;grid-template-columns:minmax(260px,380px) 1fr;
    gap:16px;align-items:stretch;
  }
  .hero-portrait{
    position:relative;border-radius:20px;overflow:hidden;
    border:1px solid var(--line);background:var(--fog);
    aspect-ratio:1/1;align-self:end;
  }
  .hero-portrait img{width:100%;height:100%;object-fit:cover}
  .hero-portrait::after{
    content:"";position:absolute;inset:0;border-radius:20px;
    box-shadow:inset 0 0 0 3px var(--poppy);opacity:0;transition:opacity .3s;
  }
  .hero-portrait:hover::after{opacity:1}
  .hero-media{
    position:relative;height:clamp(300px,46vh,520px);
    border-radius:20px;overflow:hidden;background:var(--fog);
    border:1px solid var(--line);
  }
  .hero-media .ph{
    position:absolute;inset:0;display:flex;flex-direction:column;
    align-items:center;justify-content:center;gap:10px;color:var(--grey);
    background:
      linear-gradient(120deg, transparent 40%, rgba(201,17,64,.07)),
      repeating-linear-gradient(-45deg, transparent 0 22px, rgba(16,16,16,.025) 22px 44px);
  }
  .ph-label{font-size:.72rem;letter-spacing:.24em;text-transform:uppercase;font-weight:500}
  .ph-note{font-size:.78rem;color:var(--grey);max-width:30ch;text-align:center}
  .hero-media img{width:100%;height:100%;object-fit:cover}
  .hero-media .credit-pill{
    position:absolute;left:16px;bottom:16px;z-index:2;
    background:rgba(16,16,16,.82);color:var(--bone);backdrop-filter:blur(6px);
    font-size:.72rem;letter-spacing:.14em;text-transform:uppercase;
    padding:8px 16px;border-radius:100px;
  }

  /* ============ TICKER — signature ============ */
  .ticker{
    background:var(--ink);color:var(--bone);
    overflow:hidden;white-space:nowrap;
    padding:16px 0;border-top:1px solid var(--ink);border-bottom:1px solid var(--ink);
  }
  .ticker-track{display:inline-flex;gap:0;animation:scroll 26s linear infinite}
  .ticker span{
    font-family:"Syne",sans-serif;font-weight:700;font-size:1.05rem;
    letter-spacing:.06em;text-transform:uppercase;padding:0 18px;
  }
  .ticker .sep{color:var(--poppy-hot)}
  @keyframes scroll{from{transform:translateX(0)}to{transform:translateX(-50%)}}

  /* ============ SECTION SHELL ============ */
  section{padding:clamp(72px,10vh,130px) 0}
  .sec-head{display:flex;justify-content:space-between;align-items:end;gap:24px;margin-bottom:clamp(36px,5vh,60px)}
  .sec-head h2{
    font-family:"Syne",sans-serif;font-weight:800;text-transform:uppercase;
    font-size:clamp(2.2rem,6vw,4.6rem);line-height:.94;letter-spacing:-.03em;
  }
  .sec-head .count{
    font-family:"Space Grotesk";font-size:.85rem;color:var(--grey);
    font-variant-numeric:tabular-nums;white-space:nowrap;padding-bottom:10px;
  }

  /* ============ WATCH ============ */
  .watch{background:var(--bone)}
  .video-grid{display:grid;grid-template-columns:1fr 1fr;gap:clamp(18px,2.5vw,32px)}
  .vcard{position:relative}
  .vframe{
    position:relative;aspect-ratio:16/9;border-radius:18px;overflow:hidden;
    background:#000;border:1px solid var(--line);
    transition:transform .35s cubic-bezier(.2,.8,.2,1), box-shadow .35s;
  }
  .vcard:hover .vframe{transform:translateY(-6px);box-shadow:0 24px 48px -20px rgba(16,16,16,.25)}
  .vframe iframe{position:absolute;inset:0;width:100%;height:100%;border:0}
  .vmeta{display:flex;justify-content:space-between;align-items:baseline;gap:16px;padding:16px 6px 0}
  .vmeta h3{font-family:"Syne";font-weight:700;font-size:1.15rem;letter-spacing:-.01em}
  .vmeta span{font-size:.78rem;color:var(--grey);letter-spacing:.1em;text-transform:uppercase;white-space:nowrap}
  .reel-card{
    margin-top:clamp(24px,3vw,36px);
    display:grid;grid-template-columns:minmax(220px,300px) 1fr;
    gap:clamp(20px,3vw,44px);align-items:center;
    border:1px solid var(--line);border-radius:18px;
    padding:clamp(18px,2.5vw,28px);background:var(--bone);
  }
  .reel-frame{
    position:relative;aspect-ratio:9/16;border-radius:14px;overflow:hidden;
    background:#000;border:1px solid var(--line);
  }
  .reel-frame iframe{position:absolute;inset:0;width:100%;height:100%;border:0}
  .reel-thumb{
    position:absolute;inset:0;width:100%;height:100%;border:0;padding:0;cursor:pointer;
    background:linear-gradient(160deg, var(--fog), #E2E2D8);
  }
  .reel-thumb .ph{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:6px;color:var(--grey)}
  .play-badge{
    position:absolute;left:50%;top:50%;transform:translate(-50%,-50%);
    width:58px;height:58px;border-radius:50%;background:var(--poppy);
    display:flex;align-items:center;justify-content:center;
    box-shadow:0 10px 24px -6px rgba(201,17,64,.55);
    transition:transform .2s, background .2s;
  }
  .play-badge svg{width:22px;height:22px;color:#fff;margin-left:2px}
  .reel-thumb:hover .play-badge{transform:translate(-50%,-50%) scale(1.08);background:var(--ink)}
  .reel-name{
    margin-top:10px;font-size:.85rem;letter-spacing:.02em;color:var(--ink-soft);font-weight:500;
  }
  .reel-link{
    display:inline-block;margin-top:18px;text-decoration:none;
    font-size:.8rem;letter-spacing:.14em;text-transform:uppercase;font-weight:600;
    color:var(--poppy);border-bottom:2px solid var(--poppy);padding-bottom:4px;
    transition:color .2s, border-color .2s;
  }
  .reel-link:hover{color:var(--ink);border-color:var(--ink)}
  .watch-callout{
    margin-top:clamp(24px,3vw,36px);
    display:flex;gap:18px;align-items:center;flex-wrap:wrap;
    border:1px solid var(--line);border-radius:18px;padding:22px 26px;
    background:var(--fog);
  }
  .watch-callout .dot{width:10px;height:10px;border-radius:50%;background:var(--poppy);flex-shrink:0}
  .watch-callout p{font-size:.95rem;color:var(--ink-soft)}
  .watch-callout p b{color:var(--ink)}

  /* ============ ABOUT ============ */
  .about{background:var(--ink);color:var(--bone)}
  .about .eyebrow{color:var(--poppy-hot)}
  .about-grid{display:grid;grid-template-columns:1fr 1fr;gap:clamp(32px,5vw,80px);align-items:start}
  .about h2{
    font-family:"Syne";font-weight:800;text-transform:uppercase;
    font-size:clamp(2rem,4.6vw,3.6rem);line-height:.96;letter-spacing:-.025em;
    margin-top:14px;
  }
  .about h2 em{font-style:normal;color:var(--poppy-hot)}
  .about-body p{color:#CFCFC6;margin-bottom:18px;font-size:1.02rem;font-weight:300}
  .about-body p b{color:var(--bone);font-weight:500}
  .facts{margin-top:34px;border-top:1px solid #2A2A27}
  .fact{
    display:flex;justify-content:space-between;gap:20px;align-items:baseline;
    padding:16px 0;border-bottom:1px solid #2A2A27;
  }
  .fact .k{font-size:.78rem;letter-spacing:.16em;text-transform:uppercase;color:#8B8B84}
  .fact .v{font-family:"Syne";font-weight:600;font-size:1rem;text-align:right}
  .fact .v i{font-style:normal;color:var(--poppy-hot)}
  .values-row{display:flex;flex-wrap:wrap;gap:8px;margin-top:26px}
  .values-row span{
    font-size:.7rem;letter-spacing:.14em;text-transform:uppercase;
    border:1px solid #3A3A36;color:#CFCFC6;padding:7px 14px;border-radius:100px;
  }

  /* ============ CREDITS ============ */
  .credits{background:var(--bone)}
  .credit-rows{border-top:1px solid var(--line)}
  .crow{
    display:grid;grid-template-columns:90px 1fr auto;gap:clamp(16px,3vw,40px);
    align-items:baseline;padding:26px 0;border-bottom:1px solid var(--line);
    transition:padding-left .3s;
    position:relative;
  }
  .crow::before{
    content:"";position:absolute;left:0;top:0;bottom:0;width:0;
    background:var(--poppy);transition:width .3s;
  }
  .crow:hover{padding-left:18px}
  .crow:hover::before{width:4px}
  .crow .yr{
    font-size:.82rem;color:var(--grey);font-variant-numeric:tabular-nums;letter-spacing:.06em;
  }
  .crow .what{font-family:"Syne";font-weight:700;font-size:clamp(1.15rem,2.4vw,1.6rem);letter-spacing:-.015em;line-height:1.15}
  .crow .where{font-size:.92rem;color:var(--grey);margin-top:5px}
  .crow .badge{
    font-size:.7rem;letter-spacing:.14em;text-transform:uppercase;color:var(--poppy);
    border:1px solid var(--poppy);border-radius:100px;padding:6px 13px;white-space:nowrap;
  }

  .norcrid-link{text-decoration:none;transition:color .2s}
  .norcrid-link:hover{color:var(--poppy)}

  /* ============ GALLERY ============ */
  .gallery{background:var(--fog)}
  .shots{
    display:grid;grid-template-columns:repeat(4,1fr);grid-auto-rows:200px;gap:14px;
  }
  .shot{
    border-radius:16px;overflow:hidden;background:var(--bone);
    border:1px solid var(--line);position:relative;
    transition:transform .3s;
  }
  .shot:hover{transform:scale(1.015)}
  .shot img{width:100%;height:100%;object-fit:cover}
  .shot .ph{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:8px;color:var(--grey);
    background:repeating-linear-gradient(-45deg, transparent 0 22px, rgba(16,16,16,.02) 22px 44px)}
  .s-a{grid-column:span 2;grid-row:span 2}
  .s-b{grid-row:span 2}
  .s-c{grid-row:span 1}
  .gallery-hint{margin-top:20px;font-size:.85rem;color:var(--grey)}
  .gallery-hint code{background:var(--bone);border:1px solid var(--line);padding:2px 8px;border-radius:6px;font-size:.78rem}

  /* ============ CONTACT ============ */
  .contact{background:var(--poppy);color:#fff;position:relative;overflow:hidden}
  .contact h2{
    font-family:"Syne";font-weight:800;text-transform:uppercase;
    font-size:clamp(2.6rem,8vw,6.5rem);line-height:.9;letter-spacing:-.03em;
  }
  .contact .sub{margin:24px 0 40px;max-width:44ch;font-size:1.05rem;color:rgba(255,255,255,.85)}
  .cta-row{display:flex;gap:14px;flex-wrap:wrap}
  .btn{
    font-size:.82rem;letter-spacing:.14em;text-transform:uppercase;font-weight:600;
    padding:16px 30px;border-radius:100px;text-decoration:none;
    transition:transform .2s, background .2s, color .2s;display:inline-block;
  }
  .btn-dark{background:var(--ink);color:var(--bone)}
  .btn-dark:hover{transform:translateY(-2px);background:#000}
  .btn-line{border:1.5px solid #fff;color:#fff}
  .btn-line:hover{background:#fff;color:var(--poppy);transform:translateY(-2px)}
  .contact .big-bg{
    position:absolute;right:-2%;bottom:-9%;
    font-family:"Syne";font-weight:800;font-size:clamp(3.5rem,11vw,10rem);
    color:rgba(255,255,255,.10);letter-spacing:-.05em;line-height:1;
    user-select:none;pointer-events:none;text-transform:uppercase;
  }
  footer{
    display:flex;justify-content:space-between;flex-wrap:wrap;gap:10px;
    margin-top:70px;padding-top:26px;border-top:1px solid rgba(255,255,255,.3);
    font-size:.78rem;letter-spacing:.08em;color:rgba(255,255,255,.8);
    position:relative;z-index:2;
  }

  /* ============ reveal ============ */
  .reveal{opacity:0;transform:translateY(26px);transition:opacity .7s ease, transform .7s ease}
  .reveal.in{opacity:1;transform:none}
  a:focus-visible,.btn:focus-visible{outline:3px solid var(--ink);outline-offset:3px}
  .contact a:focus-visible{outline-color:#fff}

  /* ============ responsive ============ */
  @media(max-width:900px){
    .hero-top{grid-template-columns:1fr}
    .hero-split{grid-template-columns:1fr}
    .hero-media{height:clamp(220px,32vh,340px)}
    .video-grid{grid-template-columns:1fr}
    .about-grid{grid-template-columns:1fr}
    .shots{grid-template-columns:repeat(2,1fr);grid-auto-rows:170px}
    .s-a{grid-column:span 2}
    .nav-links a:not(.book){display:none}
    .crow{grid-template-columns:64px 1fr}
    .reel-card{grid-template-columns:1fr}
    .reel-frame{max-width:300px;margin:0 auto}
    .crow .badge{grid-column:2;justify-self:start;margin-top:8px}
  }
  @media(prefers-reduced-motion:reduce){
    .ticker-track{animation:none}
    .reveal{transition:none;opacity:1;transform:none}
    html{scroll-behavior:auto}
  }
</style>
</head>
<body>

<nav class="nav">
  <a class="logo" href="#top">Jennie<span>OSDL</span></a>
  <div class="nav-links">
    <a href="#watch">Watch</a>
    <a href="#about">About</a>
    <a href="#credits">Credits</a>
    <a href="#gallery">Photos</a>
    <a href="#contact" class="book">Book Jennie</a>
  </div>
</nav>

<!-- ============ HERO ============ -->
<header class="hero" id="top">
  <div class="wrap hero-top">
    <div>
      <span class="eyebrow">San Francisco Bay Area · RID CI/CT</span>
      <h1 style="margin-top:16px">
        Jennie<br>
        <span class="outline">DeLeon</span><br>
        <span class="accent">Signs.</span>
      </h1>
    </div>
    <div class="hero-side">
      <p><b>ASL/English interpreter for music &amp; theater.</b> Nationally certified. 25+ years on the platform — from club stages to stadium concerts.</p>
      <div class="hero-tags">
        <span class="tag hot">Performance</span>
        <span class="tag">Music</span>
        <span class="tag">Theater</span>
        <span class="tag">Coordination</span>
      </div>
    </div>
  </div>

  <div class="wrap">
    <div class="hero-split">
      <div class="hero-portrait">
        <img src="data:image/jpeg;base64," alt="Jennie O'Shaughnessy DeLeon">
        <span class="credit-pill">Jennie · SF Bay Area</span>
      </div>
      <div class="hero-media">
        <!-- Replace with: <img src="stage.jpg" alt="Jennie DeLeon interpreting on stage"> -->
        <div class="ph">
          <span class="ph-label">Performance shot</span>
          <span class="ph-note">Wide on-stage photo goes here — mid-song is the move.</span>
        </div>
        <span class="credit-pill">On stage</span>
      </div>
    </div>
  </div>

  <div class="ticker" aria-hidden="true" style="margin-top:clamp(28px,4vh,52px)">
    <div class="ticker-track">
      <span>ASL</span><span class="sep">✺</span><span>Music</span><span class="sep">✺</span><span>Theater</span><span class="sep">✺</span><span>Certified CI/CT</span><span class="sep">✺</span><span>Bay Area</span><span class="sep">✺</span><span>Since 1999</span><span class="sep">✺</span>
      <span>ASL</span><span class="sep">✺</span><span>Music</span><span class="sep">✺</span><span>Theater</span><span class="sep">✺</span><span>Certified CI/CT</span><span class="sep">✺</span><span>Bay Area</span><span class="sep">✺</span><span>Since 1999</span><span class="sep">✺</span>
    </div>
  </div>
</header>

<!-- ============ WATCH ============ -->
<section class="watch reveal" id="watch">
  <div class="wrap">
    <div class="sec-head">
      <h2>Watch</h2>
      <span class="count">Selected performances</span>
    </div>
    <div class="video-grid">
      <div class="vcard">
        <div class="vframe">
          <iframe src="https://www.youtube.com/embed/TSVF-f5Z97M" title="Performance interpretation" loading="lazy" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
        </div>
        <div class="vmeta"><h3>Live Performance</h3><span>Platform · Music</span></div>
      </div>
      <div class="vcard">
        <div class="vframe">
          <iframe src="https://www.youtube.com/embed/QuHbwPx4lWE" title="Performance interpretation" loading="lazy" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
        </div>
        <div class="vmeta"><h3>Live Performance</h3><span>Platform · Music</span></div>
      </div>
    </div>
    <div class="reel-card">
      <div class="reel-frame" id="reelFrame">
        <button class="reel-thumb" onclick="document.getElementById('reelFrame').innerHTML='&lt;iframe src=&quot;https://www.facebook.com/plugins/video.php?href=https%3A%2F%2Fwww.facebook.com%2Freel%2F938333582014323%2F&amp;show_text=false&amp;autoplay=true&quot; title=&quot;Jennie with Bobbie Beth — Facebook reel&quot; allow=&quot;clipboard-write; encrypted-media; picture-in-picture; web-share; autoplay&quot; allowfullscreen scrolling=&quot;no&quot;&gt;&lt;/iframe&gt;'" aria-label="Play reel: Jennie with Bobbie Beth Scoggins">
          <!-- Replace this placeholder with: <img src="reel-thumb.jpg" alt="Jennie with Bobbie Beth Scoggins"> as a background, or swap the whole .ph block for an <img> -->
          <span class="ph" style="position:absolute">
            <span class="ph-label">Reel thumbnail</span>
            <span class="ph-note">Drop a still from the clip here</span>
          </span>
          <span class="play-badge" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
          </span>
        </button>
      </div>
      <div class="reel-copy">
        <span class="eyebrow">Reel</span>
        <h3 class="syne" style="font-weight:700;font-size:clamp(1.3rem,2.6vw,1.9rem);margin-top:10px;letter-spacing:-.015em">With Bobbie Beth</h3>
        <p class="reel-name">Bobbie Beth Scoggins, Interim CEO of the National Association of the Deaf</p>
        <p style="color:var(--ink-soft);margin-top:12px;max-width:44ch">Jennie side by side with Bobbie Beth — the kind of on-camera chemistry that shows why performance interpreting is a craft.</p>
